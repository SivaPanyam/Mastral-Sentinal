# Mastra Sentinel Environment Variables Example

# ==========================================
# 1. Gemini AI Integration (Server-Side)
# ==========================================
# AI Studio automatically injects this at runtime from user secrets.
# For local development, set this to your Google AI Studio Gemini API key.
GEMINI_API_KEY="your_gemini_api_key_here"
ENKRYPTAI_API_KEY="your_enkrypt_api_key_here"

# ==========================================
# 2. Host and Network Settings
# ==========================================
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
APP_URL="http://localhost:3000"
BACKEND_PORT=8000
FRONTEND_PORT=3000

# ==========================================
# 3. Security & Credentials
# ==========================================
SECRET_KEY="supersecret_production_ready_hash_token_key"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==========================================
# 4. Durable PostgreSQL Config
# ==========================================
POSTGRES_SERVER="localhost"
POSTGRES_USER="mastra_user"
POSTGRES_PASSWORD="your_postgres_password_here"
POSTGRES_DB="mastra_sentinel"
POSTGRES_PORT="5432"
DATABASE_URL="postgresql+psycopg2://mastra_user:your_postgres_password_here@postgres:5432/mastra_sentinel"

# ==========================================
# 5. Qdrant Vector DB & RAG Ingestion
# ==========================================
QDRANT_HOST="localhost"
QDRANT_PORT=6333
QDRANT_API_KEY=""
QDRANT_COLLECTION="sentinel_kb"
